    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tron0/shared": "workspace:*",
    "bitecs": "^0.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsdom": "^29.0.2",
    "jsdom-worker": "^0.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
