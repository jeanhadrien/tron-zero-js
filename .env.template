# Local development — copy to .env (gitignored)
VITE_LOG_LEVEL=INFO
VITE_OTEL_ENABLED=false
VITE_MANAGER_URL=http://localhost:3001

# Game server (local)
MANAGER_URL=http://localhost:3001
ADVERTISED_HOST=localhost
SERVER_NAME=Local Server
MAX_PLAYERS=10

# GCP (optional, for local gcloud tooling)
GOOGLE_CLOUD_PROJECT=tron-zero-js
GOOGLE_CLOUD_LOCATION=europe-west1

# Production URLs are set in GitHub Actions, not here:
#   VITE_MANAGER_URL=https://server-manager.tronzero.dev  (client build in deploy-release.yml)
#   MANAGER_URL=https://server-manager.tronzero.dev         (game server env on GCE VM)