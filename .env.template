# Copy per-package env files before running locally.
# See packages/client/README.md and docs/release-and-deploy.md.

# ── Client (packages/client/.env.development) ──────────────────────────────
# VITE_MANAGER_URL=http://localhost:3001

# ── Game server (packages/server/.env.local — gitignored) ──────────────────
# MANAGER_URL=http://localhost:3001
# ADVERTISED_HOST=localhost
# ADVERTISED_PORT=3000
# ADVERTISED_SECURE=false
# PORT=3000
# SERVER_NAME=Local Server
# MAX_PLAYERS=10
#
# WSL2 + Windows browser: keep ADVERTISED_HOST=localhost (WSL forwards it).
# packages/server/.env.development also sets:
#   WEBRTC_BIND_ADDRESS=127.0.0.1  (loopback ICE candidates — required on WSL2)
#   WEBRTC_PORT_MIN/MAX=10000-20000  (match Hyper-V UDP firewall rule)
# Do NOT use a LAN IP for ADVERTISED_HOST.
#
# If WebRTC still times out, confirm mirrored networking in %USERPROFILE%\.wslconfig:
#   [wsl2]
#   networkingMode=mirrored
# Then run: wsl --shutdown

# ── Production game server (packages/server/.env.production) ───────────────
# MANAGER_URL=https://server-manager.tronzero.dev
# ADVERTISED_PORT=443
# ADVERTISED_SECURE=true
# WEBRTC_PORT_MIN=10000
# WEBRTC_PORT_MAX=20000